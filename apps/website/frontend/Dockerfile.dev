# Development Dockerfile for Frontend (React + Vite)
# Optimized for hot-reload and fast iteration

FROM node:20-alpine

# Set working directory
WORKDIR /app

# Copy package files
COPY package*.json ./

# Install dependencies
# Using npm install instead of npm ci for development flexibility
RUN npm install

# Copy source code (overridden by bind mount in docker-compose)
COPY . .

# Expose Vite dev server port
EXPOSE 5173

# Start Vite dev server
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]
