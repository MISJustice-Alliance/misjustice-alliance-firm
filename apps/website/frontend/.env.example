# MISJustice Alliance Frontend Environment Variables
# Copy this file to .env and update with actual values

# Session Messenger Configuration
VITE_SESSION_ID=05b91206d21de1fe1a00e18d8ee1bce06cfcaf22fd3025bc0f0065e675e6722324

# Quiet Messenger Configuration
VITE_QUIET_ADDRESS=misjustice-alliance-contact

# Email Configuration
VITE_CONTACT_EMAIL=contact@misjustice.org
VITE_PGP_FINGERPRINT=ABCD 1234 EFGH 5678 IJKL 9012 MNOP 3456 QRST 7890
VITE_PGP_PUBLIC_KEY_URL=/api/public-key

# Tor Configuration
VITE_TOR_ONION_ADDRESS=misjusticexyz123abc.onion

# Arweave / Turbo.io Configuration
# Turbo upload endpoint for Arweave document storage
VITE_TURBO_UPLOAD_URL=https://upload.ardrive.io

# Use mock Arweave uploads for development (default: true)
# IMPORTANT: Set to 'false' in production to use real Arweave uploads
# Production requires Turbo SDK loaded via script tag in index.html
# Development mode generates valid-looking transaction IDs for testing
VITE_USE_MOCK_ARWEAVE=true
