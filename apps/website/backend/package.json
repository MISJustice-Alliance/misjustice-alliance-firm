{
  "name": "misjustice-backend",
  "version": "1.0.0",
  "description": "MISJustice Alliance Legal Advocacy Platform - Backend API",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon --exec ts-node src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:unit": "jest tests/unit",
    "test:integration": "jest tests/integration",
    "test:debug": "node --inspect-brk node_modules/.bin/jest --runInBand",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "type-check": "tsc --noEmit",
    "migrate": "node -r ts-node/register migrations/run.ts",
    "seed:cases": "ts-node src/scripts/seedCases.ts",
    "archive:arweave": "ts-node src/scripts/archiveCasesToArweave.ts",
    "arns:backfill": "ts-node src/scripts/backfillArnsUndernames.ts",
    "arns:backfill:dry-run": "ts-node src/scripts/backfillArnsUndernames.ts --dry-run",
    "integrate:cr2024002": "ts-node src/scripts/integrateCR2024002.ts",
    "integrate:cr2024002:dry-run": "ts-node src/scripts/integrateCR2024002.ts --dry-run",
    "integrate:evidence": "ts-node src/scripts/integrateEvidence.ts",
    "integrate:evidence:dry-run": "ts-node src/scripts/integrateEvidence.ts --dry-run",
    "db:benchmark": "ts-node src/scripts/performanceBenchmark.ts",
    "db:monitor": "ts-node -e \"require('./src/utils/databaseMonitoring').default.logDatabaseHealth()\"",
    "db:stats": "ts-node -e \"const {logPoolStats,getQueryStats}=require('./src/config/database');logPoolStats();console.log('Query Stats:',getQueryStats())\"",
    "analyze:documents": "ts-node src/scripts/analyzeExistingDocuments.ts",
    "analyze:documents:dry-run": "ts-node src/scripts/analyzeExistingDocuments.ts --dry-run",
    "reconcile:arns": "ts-node src/scripts/reconcileArnsRecords.ts",
    "reconcile:arns:dry-run": "ts-node src/scripts/reconcileArnsRecords.ts --dry-run",
    "reanalyze:failed-ocr": "ts-node src/scripts/reanalyzeFailedOcr.ts"
  },
  "keywords": [
    "legal",
    "advocacy",
    "civil-rights",
    "arweave",
    "permaweb"
  ],
  "author": "MISJustice Alliance",
  "license": "AGPL-3.0",
  "dependencies": {
    "@ar.io/sdk": "^3.22.2",
    "@ardrive/turbo-sdk": "^1.39.2",
    "@bitwarden/sdk-napi": "^1.0.0",
    "@types/multer": "^2.0.0",
    "arweave": "^1.15.7",
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-validator": "^7.0.1",
    "form-data": "^4.0.5",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mailgun.js": "^12.5.0",
    "morgan": "^1.10.0",
    "multer": "^2.0.2",
    "pdf-parse": "^1.1.1",
    "pdf2pic": "^3.2.0",
    "pg": "^8.11.3",
    "tesseract.js": "^7.0.0",
    "winston": "^3.11.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.10.6",
    "@types/pdf-parse": "^1.1.5",
    "@types/pg": "^8.10.9",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "prettier": "^3.1.1",
    "supertest": "^6.3.4",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=9.0.0"
  },
  "overrides": {
    "elliptic": "6.6.1",
    "secp256k1": "5.0.1",
    "ws": "8.19.0",
    "preact": "10.28.2"
  }
}
