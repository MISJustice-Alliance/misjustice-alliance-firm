# Environment Configuration
# NOTE: If using Docker Compose, environment variables are set in docker compose.yml
# This file is for manual/local development WITHOUT Docker

# Server Configuration
NODE_ENV=development
PORT=3000
API_BASE_URL=http://localhost:3000

# Database Configuration
# For Docker: Use DATABASE_HOST=postgres (service name)
# For local: Use DATABASE_HOST=localhost
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=misjustice_dev
DATABASE_USER=postgres
DATABASE_PASSWORD=your_password_here
DATABASE_SSL=false

# JWT Configuration
# IMPORTANT: Generate a secure random secret (minimum 32 characters)
# Run: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Then replace GENERATE_YOUR_OWN_SECRET_HERE with the output
JWT_SECRET=GENERATE_YOUR_OWN_SECRET_HERE
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# Arweave Configuration (for Phase 3)
ARWEAVE_GATEWAY=https://arweave.net
ARWEAVE_WALLET_PATH=./wallet.json
TURBO_UPLOAD_KEY=your_turbo_key_here

# Logging
LOG_LEVEL=info
LOG_FILE=logs/app.log

# CORS Configuration
CORS_ORIGIN=http://localhost:5173

# ============================================================================
# BITWARDEN SECRETS MANAGER (RECOMMENDED FOR PRODUCTION)
# ============================================================================
# Bitwarden Secrets Manager provides enterprise-grade secrets management with:
# - End-to-end AES-256 encryption
# - Centralized secrets across environments
# - Audit logging and secret rotation
# - Team collaboration with role-based access
#
# Sign up at: https://bitwarden.com/products/secrets-manager/
# Documentation: docs/bitwarden-setup.md
#
# When configured, Bitwarden overrides the following secrets below:
# - JWT_SECRET
# - MAILGUN_API_KEY
# - MAILGUN_DOMAIN
# - MAILGUN_WEBHOOK_SIGNING_KEY
# - DATABASE_PASSWORD (optional override)
# ============================================================================

# Machine account access token from Bitwarden Secrets Manager
# Get from: https://vault.bitwarden.com → Organizations → Secrets Manager → Access Tokens
# Format: 0.xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx.yyyyyyyyyyyyyyyyyyyyyyyy:zzzzzzzzzzzzzzzzzzzz==
# REQUIRED FOR PRODUCTION
BW_ACCESS_TOKEN=

# Organization/Project ID for your secrets
# Get from: https://vault.bitwarden.com → Organizations → Your Org → Projects
# Format: xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# REQUIRED FOR PRODUCTION
BW_PROJECT_ID=

# Bitwarden API URL (optional, defaults to https://vault.bitwarden.com)
# For self-hosted Bitwarden instances only
BW_URL=https://vault.bitwarden.com

# ============================================================================
# DEVELOPMENT FALLBACK SECRETS (ONLY USED IF BITWARDEN NOT CONFIGURED)
# ============================================================================
# The following secrets are ONLY used when Bitwarden is not configured
# DO NOT use these values in production - they are insecure placeholders
# ============================================================================

# Mailgun Email Service Configuration
# Sign up at: https://signup.mailgun.com/
# Get your API key from: https://app.mailgun.com/app/account/security/api_keys
# IMPORTANT: Use your PRIVATE API key (starts with "key-"), NOT the public validation key
MAILGUN_API_KEY=your_mailgun_private_api_key_here
MAILGUN_DOMAIN=send.misjusticealliance.org
MAILGUN_API_URL=https://api.mailgun.net
# Webhook signing key from: https://app.mailgun.com/app/sending/domains/YOUR_DOMAIN/webhooks
MAILGUN_WEBHOOK_SIGNING_KEY=your_webhook_signing_key_here

# Venice.ai API for AI-powered document analysis
# Get your API key from: https://venice.ai/settings/api
# Used for generating document synopsis and metadata tags
# Models used:
#   - qwen3-235b: PDF text analysis (successor to llama-3.1-405b)
#   - mistral-31-24b: Image vision/OCR
VENICE_API_KEY=your_venice_api_key_here
