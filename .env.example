# MISJustice Alliance Firm — Local Development Environment
# -----------------------------------------------------------------------------
# Copy this file to `.env` and adjust secrets before running `docker compose up`.
# NEVER commit `.env` to version control.
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# MCAS API
# -----------------------------------------------------------------------------
MCAS_ENV=development
MCAS_SECRET_KEY=dev-secret-change-me-in-production
MCAS_DATABASE_URL=postgresql+asyncpg://mcas:mcas@postgres:5432/mcas
MCAS_REDIS_URL=redis://redis:6379/0
MCAS_MINIO_ENDPOINT=minio:9000
MCAS_MINIO_ACCESS_KEY=minioadmin
MCAS_MINIO_SECRET_KEY=minioadmin
MCAS_NEO4J_URI=bolt://neo4j:7687
MCAS_NEO4J_USER=neo4j
MCAS_NEO4J_PASSWORD=neo4jpassword
MCAS_ELASTICSEARCH_URL=http://elasticsearch:9200
MCAS_QDRANT_URL=http://qdrant:6333

# MCAS test database (used by CI)
TEST_DATABASE_URL=postgresql+asyncpg://mcas:mcas@postgres:5432/mcas_test

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
POSTGRES_USER=mcas
POSTGRES_PASSWORD=mcas
POSTGRES_DB=mcas

# -----------------------------------------------------------------------------
# Neo4j
# -----------------------------------------------------------------------------
NEO4J_AUTH=neo4j/neo4jpassword
NEO4J_AUTH_USER=neo4j
NEO4J_AUTH_PASSWORD=neo4jpassword
NEO4J_HEAP_MAX=1G
NEO4J_PAGECACHE=512M

# -----------------------------------------------------------------------------
# SearXNG
# -----------------------------------------------------------------------------
SEARXNG_BASE_URL=http://localhost/search
SEARXNG_SECRET=change-me-in-production
SEARXNG_WORKERS=4
SEARXNG_THREADS=4

# -----------------------------------------------------------------------------
# LiteLLM Proxy
# -----------------------------------------------------------------------------
LITELLM_MASTER_KEY=sk-litellm-local
LITELLM_SALT_KEY=salt-local-change-me
LITELLM_DATABASE_URL=postgresql://mcas:mcas@postgres:5432/litellm

# -----------------------------------------------------------------------------
# MinIO
# -----------------------------------------------------------------------------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# -----------------------------------------------------------------------------
# n8n
# -----------------------------------------------------------------------------
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=admin
N8N_HOST=localhost
N8N_WEBHOOK_URL=http://localhost/n8n/
N8N_ENCRYPTION_KEY=change-me-in-production
